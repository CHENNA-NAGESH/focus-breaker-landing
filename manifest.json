{
  "manifest_version": 3,
  "name": "Focus Breaker",
  "description": "Reduce entertainment website addiction by allowing timed use followed by automatic blocking.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Breaker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "declarativeNetRequest",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html",
        "blocked.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
